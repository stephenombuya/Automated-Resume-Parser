# ============================================
# Resume Parser - Development Environment
# ============================================

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Secret Keys (Generate these with: openssl rand -hex 32)
SECRET_KEY=dev-secret-key-change-in-production-1234567890
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production-1234567890
API_KEY_SALT=dev-api-salt-change-in-production

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/resume_parser_dev
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_SSL_MODE=disable

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_SSL=false
RATE_LIMIT_ENABLED=true

# File Upload Configuration
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE_MB=10
STORAGE_BACKEND=local
ASYNC_PROCESSING=false

# Security Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
RATE_LIMIT_ENABLED=true
SESSION_COOKIE_SECURE=false
HSTS_ENABLED=false

# Admin Configuration
ADMIN_PASSWORD=admin123
ADMIN_API_KEY=dev-admin-api-key-123456

# Webhook Configuration
WEBHOOK_SECRET=dev-webhook-secret-123456

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FILE_ENABLED=true
LOG_FILE_PATH=logs/app.log
JSON_LOGGING=false

# Feature Flags
ENABLE_OCR=false
ENABLE_ML_SKILLS_EXTRACTION=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SLACK_INTEGRATION=false
ENABLE_CACHING=true
ENABLE_ASYNC_PROCESSING=false
ENABLE_BETA_API=true

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=false
