# ============================================
# Resume Parser - Testing Environment
# ============================================

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=testing
FLASK_DEBUG=1
FLASK_HOST=127.0.0.1
FLASK_PORT=5001

# Secret Keys (Test values)
SECRET_KEY=test-secret-key-for-testing-only
JWT_SECRET_KEY=test-jwt-secret-key-for-testing
API_KEY_SALT=test-api-salt

# Database Configuration (Use separate test database)
DATABASE_URL=postgresql://postgres:password@localhost:5432/resume_parser_test
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_SSL_MODE=disable

# Redis Configuration (Optional for tests)
REDIS_URL=redis://localhost:6379/1
RATE_LIMIT_ENABLED=false

# File Upload Configuration
UPLOAD_FOLDER=test_uploads
MAX_FILE_SIZE_MB=10
STORAGE_BACKEND=local
ASYNC_PROCESSING=false

# Security Configuration (Disabled for tests)
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_ENABLED=false
SESSION_COOKIE_SECURE=false
HSTS_ENABLED=false

# Logging Configuration (Minimal for tests)
LOG_LEVEL=WARNING
LOG_FILE_ENABLED=false
JSON_LOGGING=false

# Feature Flags (Disabled for tests)
ENABLE_OCR=false
ENABLE_ML_SKILLS_EXTRACTION=false
ENABLE_CACHING=false
ENABLE_ASYNC_PROCESSING=false
